  <td rowspan="2" align="center" class="clickable">
    РћРїР»Р°С‡РµРЅРѕ РІ РјС–СЃСЏС†С–<br>(С‡РёСЃР»Рѕ, СЃСѓРјР°, РїРµСЂС–РѕРґ)
  </td>
  <td rowspan="2" align="center" class="clickable">
    Р‘РѕСЂРі(+) РџРµСЂРµРїР»Р°С‚Р°(-) РЅР° РєС–РЅРµС†СЊ РјС–СЃСЏС†СЏ
  </td>
`;

    // Р”РѕР±Р°РІР»СЏРµРј РѕР±СЂР°Р±РѕС‚С‡РёРє РєР»РёРєРѕРІ Рє Р·Р°РіРѕР»РѕРІРєР°Рј
    //Array.from(headerRow.children).forEach(function (header, index) {
    //  header.addEventListener("click", handleHeaderClick);
    //});
    thead.appendChild(headerRow);

    // Р’С‚РѕСЂРѕР№ СЂСЏРґ Р·Р°РіРѕР»РѕРІРєР° СЃ РЅР°Р·РІР°РЅРёСЏРјРё СѓСЃР»СѓРі
    var servicesRow = document.createElement("tr");
    services.forEach(function (serviceId) {
      if (serviceId != 7) {
      	var serviceName = us[serviceId] || `РЈСЃР»СѓРіР° ${serviceId}`;
        var serviceHeader = document.createElement("td");
        serviceHeader.setAttribute("align", "CENTER");
        serviceHeader.textContent = serviceName;
        serviceHeader.classList.add("clickable"); // Р”РѕР±Р°РІР»СЏРµРј РєР»Р°СЃСЃ

        // РќР°РІРµС€РёРІР°РµРј РѕР±СЂР°Р±РѕС‚С‡РёРє РєР»РёРєР°
