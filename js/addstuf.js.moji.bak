      }
    });
    thead.appendChild(servicesRow); // Р”РѕР±Р°РІР»СЏРµРј СЃС‚СЂРѕРєСѓ СЃ СѓСЃР»СѓРіР°РјРё РІ Р·Р°РіРѕР»РѕРІРѕРє


if (cumulativeBalance !== 0) {
